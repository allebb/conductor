{
    "name": "allebb/conductor",
    "description": "Conductor is a CLI tool to aid provisioning and maintenance of PHP based sites and applications.",
    "license": "MIT",
    "type": "project",
    "authors": [
        {
            "name": "Bobby Allen",
            "email": "ballen@bobbyallen.me"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-posix": "*",
        "ext-json": "*",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "classmap": [
            "bin/inc/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
